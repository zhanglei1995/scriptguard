{
  "name": "@scriptguard/extension",
  "version": "0.1.0",
  "description": "ScriptGuard 浏览器扩展 (Manifest V3)",
  "author": "ScriptGuard Team",
  "homepage": "https://github.com/scriptguard/scriptguard",
  "repository": {
    "type": "git",
    "url": "https://github.com/scriptguard/scriptguard",
    "directory": "apps/extension"
  },
  "bugs": {
    "url": "https://github.com/scriptguard/scriptguard/issues"
  },
  "keywords": [
    "userscript",
    "tampermonkey",
    "greasemonkey",
    "security",
    "monitoring",
    "chrome-extension"
  ],
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "plasmo dev",
    "dev:reload": "plasmo dev --target=firefox-mv2",
    "build": "plasmo build",
    "build:firefox": "plasmo build --target=firefox-mv2",
    "build:edge": "plasmo build --target=edge-mv3",
    "build:prod": "plasmo build --prod",
    "package": "plasmo package",
    "package:firefox": "plasmo package --target=firefox-mv2",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "analyze": "node scripts/analyze-bundle.js",
    "clean": "rm -rf .plasmo build dist node_modules/.cache"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@plasmohq/messaging": "0.7.2",
    "@plasmohq/storage": "^1.11.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dexie": "^4.4.4",
    "lucide-react": "^0.460.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@plasmohq/parcel-config": "0.42.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.279",
    "@types/node": "^20.14.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^15.11.6",
    "plasmo": "0.90.5",
    "postcss": "^8.4.49",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.4.5",
    "vitest": "^2.1.5"
  },
  "manifest": {
    "name": "ScriptGuard",
    "short_name": "ScriptGuard",
    "description": "用户脚本健康监控与管理平台 - 监控脚本健康状态，自动检测变更和异常行为",
    "version": "0.1.0",
    "default_locale": "zh_CN",
    "icons": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    },
    "permissions": [
      "storage",
      "alarms",
      "notifications",
      "activeTab",
      "scripting"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "action": {
      "default_title": "ScriptGuard",
      "default_popup": "popup.html",
      "default_icon": {
        "16": "assets/icon-16.png",
        "48": "assets/icon-48.png",
        "128": "assets/icon-128.png"
      }
    },
    "background": {
      "service_worker": "background.js"
    },
    "web_accessible_resources": [
      {
        "resources": [
          "assets/*"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
    },
    "offline_enabled": false
  }
}
