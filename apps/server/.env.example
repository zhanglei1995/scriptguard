# ====================================
# ScriptGuard Server Environment
# ====================================
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000,chrome-extension://*

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/scriptguard

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=replace-with-32-byte-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# External Services
PLASMO_PUBLIC_API_URL=http://localhost:3000
