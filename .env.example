# ====================================
# ScriptGuard - 环境变量示例
# ====================================
# 复制此文件为 .env.local 并填入实际值（不要提交 .env.local）

# ===== 通用 =====
NODE_ENV=development
LOG_LEVEL=info

# ===== 服务端 (apps/server) =====
# DATABASE_URL=postgresql://user:password@localhost:5432/scriptguard
# REDIS_URL=redis://localhost:6379
# JWT_SECRET=replace-with-32-byte-random-string
# PORT=3000
# HOST=0.0.0.0

# ===== 浏览器插件 (apps/extension) =====
# PLASMO_PUBLIC_API_URL=http://localhost:3000
# PLASMO_PUBLIC_SENTRY_DSN=

# ===== 云端测试 Runner =====
# PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
# RUNNER_MAX_CONCURRENCY=3
